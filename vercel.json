{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "functions": {
    "api/simulate.mjs": {
      "maxDuration": 300
    },
    "api/billing/*.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/site/simulation.html"
    },
    {
      "source": "/ja",
      "destination": "/site/simulation-ja.html"
    },
    {
      "source": "/ja/docs",
      "destination": "/site/docs-ja.html"
    },
    {
      "source": "/mora",
      "destination": "/site/index.html"
    },
    {
      "source": "/mora/ja",
      "destination": "/site/index-ja.html"
    },
    {
      "source": "/mora.html",
      "destination": "/site/index.html"
    },
    {
      "source": "/decision-foundation",
      "destination": "/site/index.html"
    },
    {
      "source": "/decision-foundation/ja",
      "destination": "/site/index-ja.html"
    },
    {
      "source": "/decision-foundation.html",
      "destination": "/site/index.html"
    },
    {
      "source": "/admin.html",
      "destination": "/site/admin.html"
    },
    {
      "source": "/admin.js",
      "destination": "/site/admin.js"
    },
    {
      "source": "/dashboard.html",
      "destination": "/site/dashboard.html"
    },
    {
      "source": "/dashboard.js",
      "destination": "/site/dashboard.js"
    },
    {
      "source": "/docs.html",
      "destination": "/site/docs.html"
    },
    {
      "source": "/docs.js",
      "destination": "/site/docs.js"
    },
    {
      "source": "/llms.txt",
      "destination": "/site/llms.txt"
    },
    {
      "source": "/docs",
      "destination": "/site/docs.html"
    },
    {
      "source": "/simulation",
      "destination": "/site/simulation.html"
    },
    {
      "source": "/simulation.html",
      "destination": "/site/simulation.html"
    },
    {
      "source": "/styles.css",
      "destination": "/site/styles.css"
    },
    {
      "source": "/main.js",
      "destination": "/site/main.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.mjs"
    },
    {
      "source": "/api/simulate",
      "destination": "/api/simulate.mjs"
    },
    {
      "source": "/api/simulations",
      "destination": "/api/simulations/index.mjs"
    },
    {
      "source": "/api/simulations/:id",
      "destination": "/api/simulations/[id].mjs?id=:id"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register.mjs"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.mjs"
    },
    {
      "source": "/api/billing/checkout",
      "destination": "/api/billing/checkout.mjs"
    },
    {
      "source": "/api/billing/claim",
      "destination": "/api/billing/claim.mjs"
    },
    {
      "source": "/api/billing/me",
      "destination": "/api/billing/me.mjs"
    },
    {
      "source": "/api/billing/auto-topup",
      "destination": "/api/billing/auto-topup.mjs"
    },
    {
      "source": "/api/billing/webhook",
      "destination": "/api/billing/webhook.mjs"
    }
  ]
}
